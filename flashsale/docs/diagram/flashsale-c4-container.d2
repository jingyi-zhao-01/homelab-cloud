direction: right

title: {
  label: "Flashsale C4 Container Diagram"
  shape: text
  style: {
    bold: true
    font-size: 28
  }
}

client: {
  label: "Customer / Load Generator"
  shape: person
  style: {
    fill: "#EFF6FF"
    stroke: "#2563EB"
    stroke-width: 2
  }
}

flashsale_system: {
  label: "Flashsale System"
  style: {
    fill: "#F8FAFC"
    stroke: "#CBD5E1"
    stroke-width: 2
  }

  user_service: {
    label: "user-service\nValidates and serves user records"
    shape: rectangle
    style: {
      fill: "#ECFDF5"
      stroke: "#059669"
    }
  }

  order_service: {
    label: "order-service\nOrchestrates order creation and terminalization"
    shape: rectangle
    style: {
      fill: "#ECFDF5"
      stroke: "#059669"
      stroke-width: 3
    }
  }

  product_service: {
    label: "product-service\nOwns product stock and reservation lifecycle"
    shape: rectangle
    style: {
      fill: "#ECFDF5"
      stroke: "#059669"
    }
  }

  user_db: {
    label: "User PostgreSQL\nusers"
    shape: cylinder
    style: {
      fill: "#FFFBEB"
      stroke: "#D97706"
    }
  }

  order_db: {
    label: "Order PostgreSQL\norders + terminalization events"
    shape: cylinder
    style: {
      fill: "#FFFBEB"
      stroke: "#D97706"
    }
  }

  product_db: {
    label: "Product PostgreSQL\nproducts + reservations"
    shape: cylinder
    style: {
      fill: "#FFFBEB"
      stroke: "#D97706"
    }
  }

  terminalization_queue: {
    label: "Postgres Queue\norder_terminalization_tasks"
    shape: queue
    style: {
      fill: "#FFF1F2"
      stroke: "#E11D48"
    }
  }
}

client -> flashsale_system.order_service: "POST /orders"
flashsale_system.order_service -> flashsale_system.user_service: "validate user"
flashsale_system.order_service -> flashsale_system.product_service: "reserve / confirm / cancel reservation"
flashsale_system.user_service -> flashsale_system.user_db: "read / write users"
flashsale_system.order_service -> flashsale_system.order_db: "persist order state"
flashsale_system.order_service -> flashsale_system.terminalization_queue: "enqueue terminalization work"
flashsale_system.product_service -> flashsale_system.product_db: "read / write product and reservation facts"
flashsale_system.terminalization_queue -> flashsale_system.order_service: "worker claims queued tasks"
flashsale_system.order_service -> flashsale_system.order_db: "record task events / retries"
