{
  "python.defaultInterpreterPath": "${workspaceFolder}/apps/control-plane-triage-agent/.venv/bin/python",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/apps/control-plane-triage-agent/src",
    "${workspaceFolder}/application/flashsale/user-service",
    "${workspaceFolder}/application/flashsale/product-service",
    "${workspaceFolder}/application/flashsale/order-service"
  ],
  "python.analysis.autoSearchPaths": true,
  "python.terminal.activateEnvironment": true,
  "python.testing.unittestArgs": [
    "-v",
    "-s",
    "./application/flashsale",
    "-p",
    "test*.py"
  ],
  "python.testing.pytestEnabled": false,
  "python.testing.unittestEnabled": true,
  "go.useLanguageServer": true,
  "go.toolsManagement.autoUpdate": true,
  "go.lintTool": "golangci-lint",
  "go.lintFlags": [
    "--config=${workspaceFolder}/apps/node-disk-janitor/.golangci.yml"
  ],
  "gopls": {
    "formatting.gofumpt": true,
    "ui.semanticTokens": true,
    "staticcheck": true
  },
  "[go]": {
    "editor.defaultFormatter": "golang.Go",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  }
}
