{
  "uid": "strategy-tester-volatility-surfaces",
  "title": "Strategy Tester Volatility Surfaces",
  "tags": ["strategy-tester", "options", "volatility", "plotly"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30m",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "label": "Namespace",
        "query": "${strategy_tester_namespace}",
        "current": { "text": "${strategy_tester_namespace}", "value": "${strategy_tester_namespace}" },
        "hide": 2
      },
      {
        "name": "underlying_asset",
        "label": "Underlying Asset",
        "type": "query",
        "hide": 2,
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": null,
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "${neon_datasource_uid}" },
        "definition": "SELECT DISTINCT underlying_ticker AS __text, underlying_ticker AS __value FROM options ORDER BY 1;",
        "query": "SELECT DISTINCT underlying_ticker AS __text, underlying_ticker AS __value FROM options ORDER BY 1;",
        "sort": 1,
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        }
      },
      {
        "name": "option_type",
        "label": "Option Type",
        "type": "custom",
        "hide": 0,
        "query": "CALL,PUT",
        "options": [
          { "selected": true, "text": "CALL", "value": "CALL" },
          { "selected": false, "text": "PUT", "value": "PUT" }
        ],
        "current": { "selected": true, "text": "CALL", "value": "CALL" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "ae3e-plotly-panel",
      "title": "$${underlying_asset} $${option_type} Volatility Surface",
      "description": "为什么重要：这张图把每个 underlying 在指定 CALL/PUT 维度下的最新 snapshot 隐含波动率曲面自动画出来。怎么看：横轴是 DTE，纵轴优先使用 moneyness（strike / underlying spot），如果 spot 尚未入库则自动回退为 strike，曲面高度是 implied volatility；如果曲面断裂或明显空洞，通常意味着 snapshot 覆盖不完整或某些 strike/expiry 没抓到。",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${neon_datasource_uid}" },
      "gridPos": { "h": 14, "w": 12, "x": 0, "y": 0 },
      "repeat": "underlying_asset",
      "repeatDirection": "h",
      "maxPerRow": 2,
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "WITH universe AS ( SELECT o.ticker, o.strike_price, o.expiration_date, o.contract_type, (o.expiration_date::date - CURRENT_DATE)::int AS dte FROM options o WHERE o.underlying_ticker = '$${underlying_asset}' AND o.contract_type = '$${option_type}' AND o.expiration_date::date >= CURRENT_DATE ), latest AS ( SELECT DISTINCT ON (s.ticker) s.ticker, s.implied_vol, s.open_interest, s.volume, s.last_crawled, s.last_updated, NULLIF(to_jsonb(s) ->> 'underlying_price', '')::double precision AS underlying_price FROM option_snapshots s JOIN universe u ON u.ticker = s.ticker ORDER BY s.ticker, s.last_crawled DESC ), max_crawl AS ( SELECT MAX(last_crawled) AS latest_crawl FROM latest ) SELECT u.ticker AS option_ticker, u.strike_price, u.expiration_date, u.contract_type AS option_type, l.implied_vol AS implied_volatility, l.open_interest, l.volume, l.last_crawled, l.last_updated, l.underlying_price, u.dte FROM universe u JOIN latest l ON l.ticker = u.ticker CROSS JOIN max_crawl m WHERE u.dte BETWEEN 1 AND 365 AND l.implied_vol IS NOT NULL AND l.implied_vol > 0 AND l.implied_vol < 5 AND l.last_crawled >= m.latest_crawl - INTERVAL '30 minutes' ORDER BY u.dte, u.strike_price;"
        }
      ],
      "options": {
        "script": "const frame = data.series?.[0];\nconst baseTitle = String(variables.underlying_asset) + ' ' + String(variables.option_type) + ' Volatility Surface';\nif (!frame || !frame.fields?.length) {\n  return {\n    data: [],\n    layout: {\n      title: baseTitle,\n      annotations: [{ text: 'No data', showarrow: false, x: 0.5, y: 0.5, xref: 'paper', yref: 'paper' }]\n    },\n    config: { displaylogo: false, responsive: true }\n  };\n}\n\nconst valuesFor = (name) => {\n  const field = frame.fields.find((candidate) => candidate.name === name);\n  if (!field) {\n    return [];\n  }\n  const values = field.values;\n  if (Array.isArray(values)) {\n    return values;\n  }\n  if (values?.buffer) {\n    return Array.from(values.buffer);\n  }\n  return Array.from(values || []);\n};\n\nconst easternFormatter = new Intl.DateTimeFormat('en-US', {\n  timeZone: 'America/New_York',\n  year: 'numeric',\n  month: '2-digit',\n  day: '2-digit',\n  hour: '2-digit',\n  minute: '2-digit',\n  second: '2-digit',\n  hour12: false,\n  timeZoneName: 'short'\n});\nconst formatEasternTime = (value) => {\n  if (value == null || value === '') {\n    return 'N/A';\n  }\n  const text = String(value).trim();\n  const numericValue = Number(text);\n  const date = Number.isFinite(numericValue) && /^\\d+$/.test(text) ? new Date(numericValue) : new Date(value);\n  if (Number.isNaN(date.getTime())) {\n    return text;\n  }\n  return easternFormatter.format(date);\n};\n\nconst dtes = valuesFor('dte').map((value) => Number(value));\nconst strikes = valuesFor('strike_price').map((value) => Number(value));\nconst impliedVols = valuesFor('implied_volatility').map((value) => value == null ? null : Number(value));\nconst underlyingPrices = valuesFor('underlying_price').map((value) => value == null ? null : Number(value));\nconst expirations = valuesFor('expiration_date').map(formatEasternTime);\nconst optionTickers = valuesFor('option_ticker').map((value) => String(value));\nconst optionTypes = valuesFor('option_type').map((value) => String(value));\n\nconst points = [];\nfor (let i = 0; i < dtes.length; i += 1) {\n  const underlyingPrice = underlyingPrices[i];\n  if (!Number.isFinite(dtes[i]) || !Number.isFinite(strikes[i]) || !Number.isFinite(impliedVols[i])) {\n    continue;\n  }\n  const hasUnderlyingPrice = Number.isFinite(underlyingPrice) && underlyingPrice > 0;\n  const moneyness = hasUnderlyingPrice ? strikes[i] / underlyingPrice : null;\n  points.push({\n    dte: dtes[i],\n    strike: strikes[i],\n    underlyingPrice: hasUnderlyingPrice ? underlyingPrice : null,\n    moneyness: Number.isFinite(moneyness) ? moneyness : null,\n    iv: impliedVols[i],\n    text: optionTickers[i] + ' (' + optionTypes[i] + ')' + '<br>Expiry (ET): ' + expirations[i] + '<br>DTE: ' + dtes[i] + '<br>Strike: ' + strikes[i] + (hasUnderlyingPrice ? '<br>Spot: ' + underlyingPrice + '<br>Moneyness: ' + moneyness.toFixed(4) : '<br>Spot: N/A') + '<br>IV: ' + impliedVols[i]\n  });\n}\n\nif (!points.length) {\n  return {\n    data: [],\n    layout: {\n      title: baseTitle,\n      annotations: [{ text: 'No plottable points', showarrow: false, x: 0.5, y: 0.5, xref: 'paper', yref: 'paper' }]\n    },\n    config: { displaylogo: false, responsive: true }\n  };\n}\n\nconst useMoneyness = points.some((point) => Number.isFinite(point.moneyness));\nconst surfaceTitle = useMoneyness ? baseTitle + ' by Moneyness' : baseTitle + ' (Strike Fallback)';\nconst yKey = useMoneyness ? 'moneyness' : 'strike';\nconst yAxisTitle = useMoneyness ? 'Moneyness (K / S)' : 'Strike Price';\nconst hoverLabel = useMoneyness ? 'Moneyness' : 'Strike';\nconst yFormatter = useMoneyness ? (value) => Number(value).toFixed(4) : (value) => String(value);\n\nconst usablePoints = points.filter((point) => Number.isFinite(point[yKey]));\nif (!usablePoints.length) {\n  return {\n    data: [],\n    layout: {\n      title: surfaceTitle,\n      annotations: [{ text: 'No plottable points', showarrow: false, x: 0.5, y: 0.5, xref: 'paper', yref: 'paper' }]\n    },\n    config: { displaylogo: false, responsive: true }\n  };\n}\n\nusablePoints.sort((left, right) => left.dte - right.dte || left[yKey] - right[yKey]);\n\nconst uniqueDtes = Array.from(new Set(usablePoints.map((point) => point.dte))).sort((left, right) => left - right);\nconst yValues = usablePoints.map((point) => point[yKey]).sort((left, right) => left - right);\nconst minY = yValues[0];\nconst maxY = yValues[yValues.length - 1];\nconst uniqueYCount = useMoneyness ? new Set(yValues.map((value) => value.toFixed(4))).size : new Set(yValues).size;\nconst yGridSize = Math.max(24, Math.min(48, uniqueYCount));\nconst yGrid = Array.from({ length: yGridSize }, (_, index) => {\n  if (yGridSize === 1) {\n    return minY;\n  }\n  return minY + ((maxY - minY) * index) / (yGridSize - 1);\n});\n\nconst groupedByDte = new Map();\nfor (const point of usablePoints) {\n  const existing = groupedByDte.get(point.dte) || [];\n  existing.push(point);\n  groupedByDte.set(point.dte, existing);\n}\nfor (const [dte, series] of groupedByDte.entries()) {\n  series.sort((left, right) => left[yKey] - right[yKey]);\n  groupedByDte.set(dte, series);\n}\n\nconst interpolateSeries = (series, yValue) => {\n  if (!series || series.length < 2) {\n    return null;\n  }\n  if (yValue < series[0][yKey] || yValue > series[series.length - 1][yKey]) {\n    return null;\n  }\n  for (let i = 0; i < series.length; i += 1) {\n    if (series[i][yKey] === yValue) {\n      return series[i].iv;\n    }\n  }\n  for (let i = 1; i < series.length; i += 1) {\n    const left = series[i - 1];\n    const right = series[i];\n    if (yValue < left[yKey] || yValue > right[yKey]) {\n      continue;\n    }\n    const width = right[yKey] - left[yKey];\n    if (width <= 0) {\n      return left.iv;\n    }\n    const ratio = (yValue - left[yKey]) / width;\n    return left.iv + (right.iv - left.iv) * ratio;\n  }\n  return null;\n};\n\nconst zMatrix = uniqueDtes.map((dte) => {\n  const series = groupedByDte.get(dte);\n  return yGrid.map((yValue) => interpolateSeries(series, yValue));\n});\n\nconst hasSurfaceValues = zMatrix.some((row) => row.some((value) => Number.isFinite(value)));\nif (!hasSurfaceValues) {\n  return {\n    data: [],\n    layout: {\n      title: surfaceTitle,\n      annotations: [{ text: 'Not enough data to build a surface', showarrow: false, x: 0.5, y: 0.5, xref: 'paper', yref: 'paper' }]\n    },\n    config: { displaylogo: false, responsive: true }\n  };\n}\n\nreturn {\n  data: [\n    {\n      type: 'surface',\n      x: uniqueDtes,\n      y: yGrid,\n      z: zMatrix,\n      connectgaps: true,\n      colorscale: 'Viridis',\n      opacity: 0.92,\n      colorbar: { title: { text: 'IV' } },\n      contours: {\n        z: {\n          show: true,\n          usecolormap: true,\n          highlightwidth: 1\n        }\n      },\n      hovertemplate: 'DTE: %%{x}<br>' + hoverLabel + ': %%{y:.4f}<br>IV: %%{z:.4f}<extra></extra>'\n    },\n    {\n      type: 'scatter3d',\n      mode: 'markers',\n      x: usablePoints.map((point) => point.dte),\n      y: usablePoints.map((point) => point[yKey]),\n      z: usablePoints.map((point) => point.iv),\n      text: usablePoints.map((point) => point.text),\n      hoverinfo: 'text',\n      marker: {\n        size: 2,\n        color: usablePoints.map((point) => point.iv),\n        colorscale: 'Viridis',\n        opacity: 0.22,\n        showscale: false\n      },\n      showlegend: false\n    }\n  ],\n  layout: {\n    title: surfaceTitle,\n    margin: { l: 0, r: 0, b: 0, t: 48 },\n    paper_bgcolor: 'rgba(0,0,0,0)',\n    plot_bgcolor: 'rgba(0,0,0,0)',\n    scene: {\n      xaxis: { title: 'DTE' },\n      yaxis: { title: yAxisTitle },\n      zaxis: { title: 'Implied Volatility' },\n      camera: { eye: { x: 1.5, y: 1.5, z: 0.8 } }\n    },\n    annotations: useMoneyness ? [] : [{ text: 'Spot not available in DB yet; showing strike fallback', showarrow: false, x: 0.5, y: 1.04, xref: 'paper', yref: 'paper', font: { size: 11 } }]\n  },\n  config: {\n    responsive: true,\n    displaylogo: false,\n    displayModeBar: false\n  }\n};",
        "onclick": "",
        "data": "[]",
        "layout": "{}",
        "config": "{}"
      }
    }
  ]
}
