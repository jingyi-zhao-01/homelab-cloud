aws_region    = "us-east-1"
cluster_name  = "openhands-k3s"
node_group_name = "spot-worker"

# Optional when you also provision terraform/k3s-spot-network into the same state bucket.
network_state_bucket = "my-tf-state-bucket"

# Otherwise set explicit network IDs here.
vpc_id = "vpc-0123456789abcdef0"
subnet_ids = [
  "subnet-0123456789abcdef0",
  "subnet-abcdef01234567890",
]

key_name = "my-admin-key"
allowed_ssh_cidrs = ["203.0.113.10/32"]
trusted_cluster_cidrs = [
  "203.0.113.20/32", # control-plane public IP, VPN range, or other trusted cluster ingress source
]

instance_types = ["t3.small", "t3a.small"]

k3s_server_url = "https://76.13.108.14:6443"
k3s_token      = "replace-me-with-the-current-k3s-token"

# When the k3s server and this worker do not share direct private networking,
# also make sure the server side is configured for external-address flannel
# routing per the k3s multicloud guidance.

node_labels = [
  "node-purpose=worker",
  "capacity-type=spot",
  "topology.kubernetes.io/region=us-east-1",
]

tags = {
  project     = "homelab-cloud"
  environment = "prod"
  managed_by  = "terraform"
}
